<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Назад"
            android:textSize="16sp"
            android:textColor="#1E90FF"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp" />

        <ImageView
            android:id="@+id/ivMainPhoto"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Остальные текстовые поля -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18 500 000 ₽"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1E3A8A" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ул. Тверская, д. 15"
                android:textSize="18sp"
                android:textColor="#1E293B" />

            <TextView
                android:id="@+id/tvDistrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="📍 Центральный район"
                android:textSize="14sp"
                android:textColor="#64748B" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/tvArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Площадь: 78.5 м²"
                android:textSize="14sp"
                android:textColor="#475569" />

            <TextView
                android:id="@+id/tvRooms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Комнат: 3"
                android:textSize="14sp"
                android:textColor="#475569" />

            <TextView
                android:id="@+id/tvFloor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Этаж: 5 из 9"
                android:textSize="14sp"
                android:textColor="#475569" />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Тип: Квартира"
                android:textSize="14sp"
                android:textColor="#475569" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Описание: Просторная квартира..."
                android:textSize="14sp"
                android:textColor="#475569" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/tvOwnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Собственник: Иванов И.И."
                android:textSize="14sp"
                android:textColor="#475569" />

            <TextView
                android:id="@+id/tvOwnerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="+7 (903) 123-45-67"
                android:textSize="14sp"
                android:textColor="#475569" />

            <Button
                android:id="@+id/btnRequestViewing"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="📅 Записаться на просмотр"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E90FF" />

            <Button
                android:id="@+id/btnAddToFavorites"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="⭐ В избранное"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E90FF" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>